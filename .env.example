# At least one provider must be configured.

OPENAI_API_KEY=
# Optional defaults: gpt-4o
# OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# 通义千问（DashScope OpenAI 兼容）
DASHSCOPE_API_KEY=
# QWEN_MODEL=qwen-plus

# 讯飞星火（OpenAI 兼容 HTTP，apiKey 一般为控制台「APIPassword」或文档要求的格式）
SPARK_API_KEY=
# SPARK_MODEL=generalv3.5

# 可选：未指定时的默认 provider：openai | anthropic | qwen | spark
DEFAULT_LLM_PROVIDER=openai
